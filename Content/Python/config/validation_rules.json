{
  "max_resolution": 2048,
  "max_bone_influences": 4,
  "allow_autofix": {
    "power_of_two": false,
    "max_resolution": false,
    "mipmaps": true,
    "srgb": true,
    "compression": true,
    "bone_influences": true
  },
  "prefix_rules": {
    "Texture2D": "T_",
    "StaticMesh": "SM_",
    "Material": "M_",
    "MaterialInstanceConstant": "MI_",
    "Blueprint": "BP_",
    "WidgetBlueprint": "WBP_",
    "AnimBlueprint": "ABP_",
    "SkeletalMesh": "SK_",
    "PhysicsAsset": "PHYS_",
    "NiagaraSystem": "NS_",
    "NiagaraEmitter": "NE_",
    "SoundWave": "S_",
    "SoundCue": "SC_",
    "ParticleSystem": "P_",
    "DataTable": "DT_",
    "CurveTable": "CT_",
    "TextureRenderTarget2D": "RT_",
    "Level": "L_",
    "World": "L_",
    "ControlRig": "CR_"
  },
  "suffix_rules": {
    "_n": {"srgb": false, "compression": ["TC_NORMALMAP", "TC_BC7"]},
    "_normal": {"srgb": false, "compression": ["TC_NORMALMAP", "TC_BC7"]},

    "_r": {"srgb": false, "compression": ["TC_GRAYSCALE"]},
    "_roughness": {"srgb": false, "compression": ["TC_GRAYSCALE"]},

    "_metallic": {"srgb": false, "compression": ["TC_GRAYSCALE"]},

    "_ao": {"srgb": false, "compression": ["TC_GRAYSCALE"]},
    "_ambientocclusion": {"srgb": false, "compression": ["TC_GRAYSCALE"]},
    "_ambient_occlusion": {"srgb": false, "compression": ["TC_GRAYSCALE"]},

    "_orm": {"srgb": false, "compression": ["TC_MASKS"]},
    "_arm": {"srgb": false, "compression": ["TC_MASKS"]},

    "_masks": {"srgb": false, "compression": ["TC_MASKS"]},
    "_mask": {"srgb": false, "compression": ["TC_MASKS"]},
    "_m": {"srgb": false, "compression": ["TC_MASKS"]},

    "_d": {"srgb": true, "compression": ["TC_DEFAULT"]},
    "_diffuse": {"srgb": true, "compression": ["TC_DEFAULT"]},
    "_albedo": {"srgb": true, "compression": ["TC_DEFAULT"]},
    "_basecolor": {"srgb": true, "compression": ["TC_DEFAULT"]},
    "_base_color": {"srgb": true, "compression": ["TC_DEFAULT"]},
    "_bc": {"srgb": true, "compression": ["TC_DEFAULT"]},
    "_color": {"srgb": true, "compression": ["TC_DEFAULT"]},

    "_spec": {"srgb": false, "compression": ["TC_GRAYSCALE"]},
    "_specular": {"srgb": false, "compression": ["TC_GRAYSCALE"]},

    "_opacity": {"srgb": false, "compression": ["TC_GRAYSCALE"]},
    "_alpha": {"srgb": false, "compression": ["TC_GRAYSCALE"]},

    "_e": {"srgb": true, "compression": ["TC_DEFAULT"]},
    "_emissive": {"srgb": true, "compression": ["TC_DEFAULT"]},

    "_h": {"srgb": false, "compression": ["TC_DISPLACEMENT"]},
    "_height": {"srgb": false, "compression": ["TC_DISPLACEMENT"]},
    "_disp": {"srgb": false, "compression": ["TC_DISPLACEMENT"]},
    "_displacement": {"srgb": false, "compression": ["TC_DISPLACEMENT"]}
  }
}
